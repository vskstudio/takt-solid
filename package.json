{
  "name": "@vskstudio/takt-solid",
  "version": "0.2.0",
  "description": "Idiomatic Solid wrapper for Takt privacy-friendly analytics",
  "license": "MIT",
  "author": "VSK Studio",
  "type": "module",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/element/index.js",
  "jsdelivr": "./dist/element/index.js",
  "sideEffects": [
    "./dist/element/index.js"
  ],
  "keywords": [
    "analytics",
    "privacy",
    "solid",
    "solidjs",
    "takt"
  ],
  "homepage": "https://github.com/vskstudio/takt-solid#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vskstudio/takt-solid.git"
  },
  "bugs": {
    "url": "https://github.com/vskstudio/takt-solid/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "solid": "./dist/index.jsx",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./element": {
      "types": "./dist/element/index.d.ts",
      "import": "./dist/element/index.js",
      "default": "./dist/element/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "size": "size-limit",
    "prepublishOnly": "pnpm build",
    "release": "pnpm build && changeset publish",
    "e2e": "playwright test"
  },
  "peerDependencies": {
    "@vskstudio/takt-core": ">=0.2.0",
    "solid-js": "^1.8"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.50.0",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.4.0",
    "@vskstudio/takt-core": "^0.2.0",
    "esbuild-plugin-solid": "^0.6.0",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "size-limit": "^11.1.6",
    "solid-js": "^1.9.0",
    "tsup": "^8.3.0",
    "tsup-preset-solid": "^2.2.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@9.0.0"
}
